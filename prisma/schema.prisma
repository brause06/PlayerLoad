generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(cuid())
  name     String?
  email    String? @unique
  password String?
  role     Role    @default(PLAYER)
  playerId String? @unique
  player   Player? @relation(fields: [playerId], references: [id])
}

model Player {
  id                String        @id @default(cuid())
  gps_id            String        @unique
  name              String
  position          String
  age               Int?
  weight            Float?
  team              String?
  top_speed_max     Float?
  injury_history    String?
  status            String        @default("ACTIVE")
  imageUrl          String?
  height            Float?
  dob               DateTime?
  contract_end      DateTime?
  blood_type        String?
  emergency_contact String?
  alerts            Alert[]
  drills            DrillData[]
  sessions          SessionData[]
  user              User?
  wellnessRecords   Wellness[]

  @@index([status])
}

model Alert {
  id        String   @id @default(cuid())
  playerId  String
  type      String
  message   String
  createdAt DateTime @default(now())
  read      Boolean  @default(false)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model Session {
  id         String        @id @default(cuid())
  date       DateTime
  type       String
  duration   Int
  microcycle String?
  opponent   String?
  notes      String?
  drills     Drill[]
  data       SessionData[]

  @@index([date])
}

model Drill {
  id        String      @id @default(cuid())
  sessionId String
  name      String
  duration  Int?
  session   Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  data      DrillData[]

  @@unique([sessionId, name])
}

model DrillData {
  id             String @id @default(cuid())
  drillId        String
  playerId       String
  total_distance Float
  hsr_distance   Float
  accelerations  Int
  decelerations  Int
  top_speed      Float
  player_load    Float
  minutes        Float  @default(0)
  match_minutes  Float? @default(0)
  drill          Drill  @relation(fields: [drillId], references: [id], onDelete: Cascade)
  player         Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([drillId, playerId])
}

model SessionData {
  id             String  @id @default(cuid())
  sessionId      String
  playerId       String
  total_distance Float
  hsr_distance   Float
  accelerations  Int
  decelerations  Int
  top_speed      Float
  player_load    Float
  minutes        Float   @default(0)
  match_minutes  Float?  @default(0)
  player         Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  session        Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, playerId])
}

model Wellness {
  id             String   @id @default(cuid())
  playerId       String
  date           DateTime
  sleep          Int
  sleepHours     Float
  energy         Int      @default(5)
  stress         Int
  fatigue        Int
  muscleSoreness Int
  statusScore    Int
  comments       String?
  jointPainMap   Json?
  musclePainMap  Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  player         Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, date])
  @@index([date])
}

model SystemSettings {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

enum Role {
  ADMIN
  STAFF
  PLAYER
}
